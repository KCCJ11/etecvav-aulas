* Descrição: 
* Ler a base menor, a base maior e a altura. Calcular e mostrar a área de um trapézio: (base menor + base maior) x altura / 2.
*/
programa {
	funcao inicio() {
		real baseMenor, baseMaior, altura, area

		escreva("Base menor: ") leia(baseMenor)
		escreva("Base maior: ") leia(baseMaior)
		escreva("Altura: ") leia(altura)

		area = ((baseMenor + baseMaior) * altura) / 2

		escreva("\nÁrea do Trapézio: ", area)
	}
}
