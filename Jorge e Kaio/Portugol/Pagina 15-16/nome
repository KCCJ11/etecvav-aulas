* Descrição: 
*Ler o nome e a idade do usuário. Calcular a idade em meses e dias. Exibir o nome e a idade em anos, meses e dias.
*/
programa {
	funcao inicio() {
		cadeia nome
		inteiro anos, meses, dias

		escreva("Digite seu nome: ")
		leia(nome)
		escreva("Digite sua idade em anos: ")
		leia(anos)

		meses = anos * 12
		dias = anos * 365

		escreva("\nOlá ", nome, "!")
		escreva("\nSua idade em anos é: ", anos)
		escreva("\nSua idade em meses é: ", meses)
		escreva("\nSua idade em dias é: ", dias)
	}
}
