* Descrição: 
* Ler o peso de uma pessoa em quilos, calcular e mostrar o peso em gramas.
*/
programa {
	funcao inicio() {
		real quilos, gramas

		escreva("Digite o peso em Quilos (kg): ")
		leia(quilos)

		gramas = quilos * 1000

		escreva("\nPeso original: ", quilos, " kg")
		escreva("\nPeso convertido: ", gramas, " gramas")
	}
}
