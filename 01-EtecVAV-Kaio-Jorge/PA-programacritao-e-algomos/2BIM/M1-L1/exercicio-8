* Descricao: O programa lê um número e percorre todos os valores de 0 até ele. Os números pares são somados em uma variável e os ímpares em outra.
             No final, o programa mostra a soma dos pares e a soma dos ímpares separadamente.
*/

#include <iostream>
using namespace std;

int main() {
    int numero;
    int somaPar = 0;
    int somaImpar = 0;

    cin >> numero;

    for (int i = 0; i <= numero; i++) {
        if (i % 2 == 0) {
            somaPar += i;
        } else {
            somaImpar += i;
        }
    }

    cout << "Soma dos pares: " << somaPar << endl;
    cout << "Soma dos impares: " << somaImpar;

    return 0;
}
