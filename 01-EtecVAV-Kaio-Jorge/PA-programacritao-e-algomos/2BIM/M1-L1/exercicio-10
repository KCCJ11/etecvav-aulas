* Descricao: O programa sorteia um número aleatório entre 1 e 100. O jogador faz vários palpites e o programa informa se o valor está muito alto ou muito baixo.
             Quando o jogador acerta, o jogo termina e mostra quantas tentativas foram feitas.
*/

#include <iostream>
#include <cstdlib>
#include <ctime>

using namespace std;

int main() {
    srand(time(0));

    int secreto = rand() % 100 + 1;
    int palpite = 0;
    int tentativas = 0;

    while (palpite != secreto) {
        cin >> palpite;
        tentativas++;

        if (palpite > secreto) {
            cout << "Muito alto" << endl;
        }
        else if (palpite < secreto) {
            cout << "Muito baixo" << endl;
        }
        else {
            cout << "Correto" << endl;
        }
    }

    cout << "Quantidade de palpites: " << tentativas;

    return 0;
}
